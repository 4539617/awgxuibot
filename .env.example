# .env - Пример конфигурации (замените на свои данные)

# ============================================
# Telegram Bot Configuration
# ============================================
# XUI Bot - для управления 3x-ui панелью
XUI_BOT_TOKEN=your_xui_bot_token_here

# AWG Bot - для управления AWG (опционально)
AWG_BOT_TOKEN=your_awg_bot_token_here

# Администраторы (общие для обоих ботов)
ADMIN_IDS=123456789,987654321
ADMIN_USERNAME=@yourusername

# ============================================
# X-UI Panel Settings
# ============================================
XUI_URL=https://localhost:12345/your-path
XUI_USERNAME=admin
XUI_PASSWORD=your_password_here
XUI_VERSION=latest
INBOUND_ID=1
XUI_DB_PATH=/etc/x-ui/x-ui.db
API_TIMEOUT=30

# ============================================
# VPN Server Settings
# ============================================
SERVER_ADDRESS=your-domain.com
SERVER_PORT=443
SERVER_IP=your-domain.com

# ============================================
# Transport & Security
# ============================================
# Тип транспорта: tcp, xhttp, ws, grpc, httpupgrade, splithttp
# ВАЖНО: Для корректной работы ОБЯЗАТЕЛЬНО укажите значение TRANSPORT
# Рекомендуется: xhttp (современный, быстрый транспорт)
TRANSPORT=xhttp

# Тип безопасности: tls, reality
# ВАЖНО: Для корректной работы ОБЯЗАТЕЛЬНО укажите значение SECURITY
# Рекомендуется: reality (более безопасный)
SECURITY=reality

# ============================================
# TLS Settings (если SECURITY=tls)
# ============================================
TLS_SNI=your-domain.com
TLS_FINGERPRINT=firefox
TLS_ALPN=http/1.1

# ============================================
# Reality Settings (если SECURITY=reality)
# ============================================
REALITY_SNI=google.com
REALITY_FINGERPRINT=firefox
REALITY_PUBLIC_KEY=your_reality_public_key_here
REALITY_SHORT_ID=your_reality_short_id_here

# ============================================
# xHTTP Settings (если TRANSPORT=xhttp)
# ============================================
XHTTP_MODE=auto

# ============================================
# Limits
# ============================================
MAX_TRAFFIC_GB=1000
MAX_DAYS=3650
MIN_DAYS=1
DEFAULT_TRAFFIC_GB=100
DEFAULT_DAYS=30

# ============================================
# Database
# ============================================
DB_PATH=/app/data/bot_users.db
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=24

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs/bot.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============================================
# NetCrazyBot Specific (AWG Management)
# ============================================
OUTPUT_DIR=/app/output

# Разрешить обычным пользователям делать DNS запросы (по умолчанию false)
# При true: обычные пользователи могут отправлять домены и получать файлы + статистику (без промежуточных сообщений)
# При false: только админы могут использовать DNS функции
ALLOW_USER_DNS_QUERIES=false